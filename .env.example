# PostgreSQL (local Docker — see docker-compose.yml)
DATABASE_URL=postgresql://inferadoc:inferadoc_secret@127.0.0.1:5433/inferadoc

# Embeddings (required for document upload and RAG search)
NOMIC_API_KEY=your_nomic_api_key_here

# Auth — change in production
JWT_SECRET=change-me-to-a-long-random-string

# Audio transcription & MoM extraction (required for MP3/WAV uploads)
GROQ_API_KEY=your_groq_api_key_here

# LLM: local Ollama (llama3.1) — no API key required.
# Ensure Ollama is running: ollama serve
# Pull the model once: ollama pull llama3.1
